# Market Data API Keys
# Get free keys at:
#   Alpha Vantage: https://www.alphavantage.co/support/#api-key
#   Finnhub: https://finnhub.io/register
#   FRED (Federal Reserve Economic Data): https://fred.stlouisfed.org/docs/api/api_key.html

ALPHA_VANTAGE_KEY=
FINNHUB_KEY=
FRED_KEY=

# Claude API (Intelligence Edition)
ANTHROPIC_API_KEY=

# Monthly spend cap in USD (default 20). Server blocks new AI calls when MTD reaches this.
AI_MONTHLY_CAP_USD=20

# Where to persist MTD usage state (default ./.ai-usage.json in CWD)
# AI_USAGE_FILE=./.ai-usage.json

# Server port (optional, defaults to 3001)
PORT=3001
